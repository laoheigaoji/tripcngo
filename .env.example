# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://0a28250e63bf217f833feabaf84a25a1.r2.cloudflarestorage.com
R2_BUCKET=tripcngo-assets
R2_PUBLIC_URL=https://static.tripcngo.com

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Gmail SMTP for Feedback Form
GMAIL_USER=
GMAIL_APP_PASSWORD=

# DeepSeek API
VITE_DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY=

# Supabase (Client-side)
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Creem Payment Checkout URL
# Creem Checkout URL (Real Mode: https://www.creem.io/payment/prod_...)
VITE_CREEM_CHECKOUT_URL=https://www.creem.io/payment/prod_5xXOa84Nq51M6OpgInrSKp
